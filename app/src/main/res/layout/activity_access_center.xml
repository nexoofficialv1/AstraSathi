<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Full Access Setup"
            android:textColor="@color/forest"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="সব অনুমতি বাধ্যতামূলক নয়। যে কাজগুলো ভয়েসে করাতে চান, শুধু তার প্রয়োজনীয় access চালু করুন।"
            android:textColor="@color/muted"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/masterAccessStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_quick_button"
            android:padding="16dp"
            android:text="Access পরীক্ষা করা হচ্ছে…"
            android:textColor="@color/forest"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="১. Screen Control" android:textColor="@color/ink" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/accessibilityStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="বন্ধ" android:textColor="@color/muted" android:textSize="14sp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="স্ক্রিন পড়া, বোতাম চাপা, লেখা, স্ক্রল, Back/Home/Recents ও screenshot।" android:textColor="@color/muted" android:textSize="14sp" />
            <Button android:id="@+id/accessibilityButton" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="10dp" android:background="@drawable/bg_primary_button" android:text="Accessibility চালু করুন" android:textAllCaps="false" android:textColor="@color/white" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="২. Notification Access" android:textColor="@color/ink" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/notificationAccessStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="বন্ধ" android:textColor="@color/muted" android:textSize="14sp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="নোটিফিকেশন পড়া, খোলা, dismiss এবং supported message-এর quick reply।" android:textColor="@color/muted" android:textSize="14sp" />
            <Button android:id="@+id/notificationAccessButton" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="10dp" android:background="@drawable/bg_primary_button" android:text="Notification access চালু করুন" android:textAllCaps="false" android:textColor="@color/white" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="৩. Voice ও Phone Permissions" android:textColor="@color/ink" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/runtimeStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="পরীক্ষা করা হচ্ছে" android:textColor="@color/muted" android:textSize="14sp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="Microphone, Contacts, Camera/Torch, Phone/Call Log ও notification permission।" android:textColor="@color/muted" android:textSize="14sp" />
            <Button android:id="@+id/runtimeButton" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="10dp" android:background="@drawable/bg_primary_button" android:text="প্রয়োজনীয় permissions দিন" android:textAllCaps="false" android:textColor="@color/white" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="৪. Special Access" android:textColor="@color/ink" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/specialStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="পরীক্ষা করা হচ্ছে" android:textColor="@color/muted" android:textSize="14sp" />
            <Button android:id="@+id/overlayButton" android:layout_width="match_parent" android:layout_height="46dp" android:layout_marginTop="10dp" android:background="@drawable/bg_quick_button" android:text="Display over other apps" android:textAllCaps="false" android:textColor="@color/forest" />
            <Button android:id="@+id/usageButton" android:layout_width="match_parent" android:layout_height="46dp" android:layout_marginTop="8dp" android:background="@drawable/bg_quick_button" android:text="Usage access" android:textAllCaps="false" android:textColor="@color/forest" />
            <Button android:id="@+id/writeSettingsButton" android:layout_width="match_parent" android:layout_height="46dp" android:layout_marginTop="8dp" android:background="@drawable/bg_quick_button" android:text="Modify system settings" android:textAllCaps="false" android:textColor="@color/forest" />
            <Button android:id="@+id/batteryButton" android:layout_width="match_parent" android:layout_height="46dp" android:layout_marginTop="8dp" android:background="@drawable/bg_quick_button" android:text="Battery optimization settings" android:textAllCaps="false" android:textColor="@color/forest" />
            <Button android:id="@+id/exactAlarmButton" android:layout_width="match_parent" android:layout_height="46dp" android:layout_marginTop="8dp" android:background="@drawable/bg_quick_button" android:text="Exact alarm/reminder access" android:textAllCaps="false" android:textColor="@color/forest" />
            <Button android:id="@+id/dndButton" android:layout_width="match_parent" android:layout_height="46dp" android:layout_marginTop="8dp" android:background="@drawable/bg_quick_button" android:text="Do Not Disturb access" android:textAllCaps="false" android:textColor="@color/forest" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="৫. Caller ও Call Control" android:textColor="@color/ink" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/dialerStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="বন্ধ" android:textColor="@color/muted" android:textSize="14sp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="Caller-এর নাম বলা, incoming/ongoing call screen, call ধরা/শেষ, speaker ও mute control। Android-এর Default Phone role আবশ্যক।" android:textColor="@color/muted" android:textSize="14sp" />
            <Button android:id="@+id/dialerButton" android:layout_width="match_parent" android:layout_height="50dp" android:layout_marginTop="10dp" android:background="@drawable/bg_primary_button" android:text="Astra Sathi-কে Default Phone করুন" android:textAllCaps="false" android:textColor="@color/white" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="৬. ‘হ্যালো সাথী’ Mode" android:textColor="@color/ink" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/wakeStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="বন্ধ" android:textColor="@color/muted" android:textSize="14sp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="চালু থাকলে persistent notification ও microphone indicator দেখা যাবে এবং battery বেশি ব্যবহার হতে পারে।" android:textColor="@color/muted" android:textSize="14sp" />
            <Button android:id="@+id/wakeButton" android:layout_width="match_parent" android:layout_height="50dp" android:layout_marginTop="10dp" android:background="@drawable/bg_primary_button" android:text="‘হ্যালো সাথী’ চালু করুন" android:textAllCaps="false" android:textColor="@color/white" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical">
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="৭. Personal Memory ও Life Context" android:textColor="@color/ink" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/memoryStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="বন্ধ" android:textColor="@color/muted" android:textSize="14sp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="5dp" android:text="পছন্দ, অভ্যাস, গাড়ির হিসাব, দেওয়া কথা, ওষুধ/উপসর্গ, command history ও অসম্পূর্ণ কাজ encrypted private storage-এ রাখবে। OTP/PIN/password/card secret রাখা হবে না।" android:textColor="@color/muted" android:textSize="14sp" />
            <Button android:id="@+id/memoryButton" android:layout_width="match_parent" android:layout_height="50dp" android:layout_marginTop="10dp" android:background="@drawable/bg_primary_button" android:text="Personal Memory চালু করুন" android:textAllCaps="false" android:textColor="@color/white" android:textStyle="bold" />
            <Button android:id="@+id/clearMemoryButton" android:layout_width="match_parent" android:layout_height="46dp" android:layout_marginTop="8dp" android:background="@drawable/bg_quick_button" android:text="সব Memory ও Life Context মুছুন" android:textAllCaps="false" android:textColor="@color/danger" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_input"
            android:padding="14dp"
            android:text="নিরাপত্তা: Astra Sathi Android security, banking protection, OTP/biometric বা অন্য app-এর protected screen bypass করবে না। Payment, message, call, permission, install/uninstall ও delete-এর আগে confirmation থাকবে।"
            android:textColor="@color/danger"
            android:textSize="14sp" />

        <Button
            android:id="@+id/backToAssistantButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/bg_primary_button"
            android:text="সহকারীতে ফিরে যান"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp" />
    </LinearLayout>
</ScrollView>
