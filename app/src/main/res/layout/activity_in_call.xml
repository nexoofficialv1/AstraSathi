<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cream"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Astra Sathi Phone"
            android:textColor="@color/forest"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/inCallCaller"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="54dp"
            android:gravity="center"
            android:text="অজানা নম্বর"
            android:textColor="@color/ink"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/inCallStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="Incoming call"
            android:textColor="@color/muted"
            android:textSize="18sp" />

        <Button
            android:id="@+id/answerCallButton"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="48dp"
            android:background="@drawable/bg_primary_button"
            android:text="কল ধরুন"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/rejectCallButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_quick_button"
            android:text="কল বাতিল করুন"
            android:textAllCaps="false"
            android:textColor="@color/danger" />

        <Button
            android:id="@+id/endCallButton"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="48dp"
            android:background="@drawable/bg_quick_button"
            android:text="কল শেষ করুন"
            android:textAllCaps="false"
            android:textColor="@color/danger"
            android:textSize="18sp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">
            <Button android:id="@+id/speakerCallButton" android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1" android:background="@drawable/bg_quick_button" android:text="Speaker" android:textAllCaps="false" android:textColor="@color/forest" />
            <Button android:id="@+id/earpieceCallButton" android:layout_width="0dp" android:layout_height="50dp" android:layout_marginStart="8dp" android:layout_weight="1" android:background="@drawable/bg_quick_button" android:text="Earpiece" android:textAllCaps="false" android:textColor="@color/forest" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal">
            <Button android:id="@+id/muteCallButton" android:layout_width="0dp" android:layout_height="50dp" android:layout_weight="1" android:background="@drawable/bg_quick_button" android:text="Mute" android:textAllCaps="false" android:textColor="@color/forest" />
            <Button android:id="@+id/unmuteCallButton" android:layout_width="0dp" android:layout_height="50dp" android:layout_marginStart="8dp" android:layout_weight="1" android:background="@drawable/bg_quick_button" android:text="Unmute" android:textAllCaps="false" android:textColor="@color/forest" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:text="বলতে পারেন—কল ধরো, কল কেটে দাও, স্পিকারফোন চালু।"
            android:textColor="@color/muted"
            android:textSize="14sp" />
    </LinearLayout>
</ScrollView>
