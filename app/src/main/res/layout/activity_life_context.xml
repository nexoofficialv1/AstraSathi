<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JARVIS — Life Context"
                android:textColor="@color/white"
                android:textSize="27sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="যা বলেছেন, কখন বলেছেন এবং কতটা নিশ্চিত—সব মিলিয়ে বর্তমান পরিস্থিতি"
                android:textColor="#D9EEE7"
                android:textSize="15sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/lifePermissionText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="18dp"
            android:layout_marginTop="16dp"
            android:layout_marginRight="18dp"
            android:text="Life Context পরীক্ষা করছি…"
            android:textColor="@color/muted"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🚗  গাড়ি ও জ্বালানি" android:textColor="@color/ink" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/vehicleContextText" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="8dp" android:text="কোনো তথ্য নেই" android:textColor="@color/ink" android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🤝  দেওয়া কথা ও কাজ" android:textColor="@color/ink" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/commitmentContextText" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="8dp" android:text="কোনো তথ্য নেই" android:textColor="@color/ink" android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="❤  স্বাস্থ্য ও ওষুধ" android:textColor="@color/ink" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:id="@+id/healthContextText" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="8dp" android:text="কোনো তথ্য নেই" android:textColor="@color/ink" android:textSize="15sp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="10dp" android:text="স্বাস্থ্য-সারাংশ রোগ নির্ণয় নয়। জরুরি বা দ্রুত বাড়তে থাকা সমস্যায় চিকিৎসা সহায়তা নিন।"
                android:textColor="@color/danger" android:textSize="13sp" />
        </LinearLayout>

        <Button
            android:id="@+id/refreshLifeContextButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:background="@drawable/bg_primary_button"
            android:text="সারাংশ রিফ্রেশ করুন"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <Button
            android:id="@+id/speakLifeCommandButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="16dp"
            android:background="@drawable/bg_primary_button"
            android:text="বাংলায় সারাংশ শুনুন"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp" />

        <Button
            android:id="@+id/lifeContextBackButton"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_margin="16dp"
            android:text="সহকারীতে ফিরুন"
            android:textAllCaps="false" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:gravity="center"
            android:text="© Astra Technologies"
            android:textColor="@color/muted"
            android:textSize="12sp" />
    </LinearLayout>
</ScrollView>
