<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_page"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingLeft="22dp"
            android:paddingTop="26dp"
            android:paddingRight="22dp"
            android:paddingBottom="30dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name_bn"
                android:textColor="@color/white"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/tagline"
                android:textColor="#D9EEE7"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="●  আমি প্রস্তুত"
                android:textColor="#9BE7C8"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/micButton"
                android:layout_width="92dp"
                android:layout_height="92dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_mic"
                android:elevation="8dp"
                android:gravity="center"
                android:text="🎙"
                android:textSize="40sp"
                android:contentDescription="কথা বলুন" />

            <TextView
                android:id="@+id/instructionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="@string/tap_to_speak"
                android:textColor="@color/white"
                android:textSize="15sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="14dp"
            android:layout_marginRight="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="JARVIS — Life Context"
                android:textColor="@color/ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/lifeStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="গাড়ি, দেওয়া কথা ও স্বাস্থ্য-লগ একসঙ্গে বুঝবে"
                android:textColor="@color/muted"
                android:textSize="14sp" />

            <Button
                android:id="@+id/lifeContextButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_primary_button"
                android:text="আমার বর্তমান পরিস্থিতি দেখুন"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="18dp"
            android:layout_marginRight="16dp"
            android:background="@drawable/bg_card"
            android:elevation="2dp"
            android:orientation="vertical">

            <EditText
                android:id="@+id/commandInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:hint="@string/hint_command"
                android:inputType="textCapSentences|textMultiLine"
                android:maxLines="3"
                android:minHeight="58dp"
                android:padding="14dp"
                android:textColor="@color/ink"
                android:textColorHint="#7E8986"
                android:textSize="16sp" />

            <Button
                android:id="@+id/runButton"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_primary_button"
                android:text="@string/run_command"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="14dp"
            android:layout_marginRight="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/examples_title"
                android:textColor="@color/ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:orientation="horizontal">
                <Button android:id="@+id/quickAlarm" style="@style/QuickButton" android:text="⏰ অ্যালার্ম" />
                <Button android:id="@+id/quickNote" style="@style/QuickButton" android:text="✎ নোট" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:id="@+id/quickWhatsApp" style="@style/QuickButton" android:text="▣ WhatsApp" />
                <Button android:id="@+id/quickWeather" style="@style/QuickButton" android:text="☀ আবহাওয়া" />
            </LinearLayout>
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                <Button android:id="@+id/quickReminder" style="@style/QuickButton" android:text="✓ রিমাইন্ডার" />
                <Button android:id="@+id/quickHelp" style="@style/QuickButton" android:text="কী বলতে পারি?" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="14dp"
            android:layout_marginRight="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ফোন নিয়ন্ত্রণ — Full Access Mode"
                android:textColor="@color/ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/accessStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Advanced control এখনো সক্রিয় নয়"
                android:textColor="@color/muted"
                android:textSize="14sp" />

            <Button
                android:id="@+id/accessCenterButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_primary_button"
                android:text="Full Access Setup খুলুন"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="14dp"
            android:layout_marginRight="16dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/recent_title"
                android:textColor="@color/ink"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/resultText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:minHeight="48dp"
                android:text="এখনও কোনো কমান্ড দেওয়া হয়নি।"
                android:textColor="@color/muted"
                android:textIsSelectable="true"
                android:textSize="15sp" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="24dp"
            android:layout_marginTop="20dp"
            android:layout_marginRight="24dp"
            android:gravity="center"
            android:text="🔒  সংবেদনশীল কাজ আপনার অনুমতি ছাড়া সম্পন্ন হবে না"
            android:textColor="@color/muted"
            android:textSize="13sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:text="@string/footer"
            android:textColor="#89938F"
            android:textSize="12sp" />
    </LinearLayout>
</ScrollView>
